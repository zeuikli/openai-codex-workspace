{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start_note.sh\"",
            "statusMessage": "載入 Codex workspace 提示"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use_guard.sh\"",
            "statusMessage": "檢查 Bash 指令安全性"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use_note.sh\"",
            "statusMessage": "整理 Bash 執行後備註"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_submit_caveman.sh\"",
            "statusMessage": "Caveman per-turn reinforcement"
          }
        ]
      }
    ]
  }
}
